{
	"info": {
		"name": "F1 Telemetry API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:3000"
		}
	],
	"item": [
		{
			"name": "1. List Drivers",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/drivers?session_key=9158",
					"host": ["{{base_url}}"],
					"path": ["drivers"],
					"query": [
						{
							"key": "session_key",
							"value": "9158",
							"description": "ID de la sesion (ej: 9158 = Practice 1 Singapore 2023)"
						}
					]
				},
				"description": "Lista los pilotos de una sesion de F1."
			}
		},
		{
			"name": "2. Get Session",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/sessions/9158",
					"host": ["{{base_url}}"],
					"path": ["sessions", "9158"]
				},
				"description": "Obtiene los detalles de una sesion especifica (circuito, pais, fecha, tipo)."
			}
		},
		{
			"name": "3. List Sessions",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/sessions?year=2024&country_name=Belgium",
					"host": ["{{base_url}}"],
					"path": ["sessions"],
					"query": [
						{
							"key": "year",
							"value": "2024",
							"description": "Año de la temporada"
						},
						{
							"key": "country_name",
							"value": "Belgium",
							"description": "Nombre del pais"
						},
						{
							"key": "session_type",
							"value": "Race",
							"description": "Tipo de sesion (Practice, Qualifying, Race)",
							"disabled": true
						},
						{
							"key": "circuit_short_name",
							"value": "Spa-Francorchamps",
							"description": "Nombre corto del circuito",
							"disabled": true
						}
					]
				},
				"description": "Lista sesiones con filtros opcionales. Al menos un filtro es requerido."
			}
		},
		{
			"name": "4. Driver Summary",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/drivers/summary?driver_number=44",
					"host": ["{{base_url}}"],
					"path": ["drivers", "summary"],
					"query": [
						{
							"key": "driver_number",
							"value": "44",
							"description": "Numero del piloto (44=Hamilton, 1=Verstappen, 16=Leclerc, 4=Norris)"
						}
					]
				},
				"description": "Informacion general de un piloto: nombre, equipo, pais, foto y sesiones en las que participo."
			}
		}
	]
}
